# =============================================================================
# 8. MATERIAL FLOW (MAIN SYSTEM TEST)
# =============================================================================

### Upload material (STUDENT / MODERATOR)
POST {{materials}}/upload
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Lecture 1 Notes",
  "description": "Intro lecture",
  "fileUrl": "https://example.com/file.pdf",
  "courseId": "{{courseId}}"
}

###

### Get materials for course (STUDENT VIEW)
GET {{materials}}/course/{{courseId}}
Authorization: Bearer {{accessToken}}

###

### Approve material (MODERATOR ONLY)
PUT {{materials}}/{{materialId}}/approve
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "approvalStatus": "APPROVED"
}

###

### Reject material
PUT {{materials}}/{{materialId}}/approve
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "approvalStatus": "REJECTED",
  "rejectionReason": "Not relevant to course"
}

###

### Delete material
DELETE {{materials}}/{{materialId}}
Authorization: Bearer {{accessToken}}


# =============================================================================
# 9. FULL FLOW TEST (IMPORTANT DEMO PATH)
# =============================================================================

### Step 1: Login Student
POST {{auth}}/login
Content-Type: application/json

{
  "universityEmail": "rana.haddad@ul.edu.lb",
  "universityId": "210001",
  "password": "Test123456"
}

###

### Step 2: Get Dashboard (copy courseId)
GET {{dashboard}}
Authorization: Bearer {{accessToken}}

###

### Step 3: Upload Material
POST {{materials}}/upload
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Midterm Summary",
  "description": "Important notes",
  "fileUrl": "https://example.com/midterm.pdf",
  "courseId": "{{courseId}}"
}

###

### Step 4: Moderator approves
PUT {{materials}}/{{materialId}}/approve
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "approvalStatus": "APPROVED"
}

###

### Step 5: Student sees approved materials
GET {{materials}}/course/{{courseId}}
Authorization: Bearer {{accessToken}}